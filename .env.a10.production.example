# Production-oriented profile for private deployment on A10-class inference nodes

ENVIRONMENT=production
LOG_LEVEL=INFO
WORKFLOW_MAX_RETRIES=2

DATABASE_URL=mysql+pymysql://suzhida:${MYSQL_PASSWORD}@mysql:3306/suzhida
REDIS_URL=redis://redis:6379/0
MILVUS_URI=http://milvus:19530
ELASTICSEARCH_URL=http://elasticsearch:9200

LLM_BASE_URL=http://vllm-qwen14b:8000/v1
EMBEDDING_BASE_URL=http://bge-m3-service:8000/v1
RERANKER_BASE_URL=http://bge-reranker-service:8000/v1

LLM_MODEL=Qwen2.5-14B-Instruct
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
